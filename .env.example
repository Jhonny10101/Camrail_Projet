# ════════════════════════════════════════════════════════════════
# CAMRAIL — Variables d'Environnement Production
# IMPORTANT : Ne jamais committer ce fichier dans Git !
# Copier en .env et renseigner les vraies valeurs
# ════════════════════════════════════════════════════════════════

# ── Sécurité JWT ─────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(64))"
CAMRAIL_SECRET_KEY=REMPLACEZ_PAR_UNE_CLE_SECRETE_LONGUE_ET_ALEATOIRE

# ── Serveur ───────────────────────────────────────────────────────
PORT=8000
WORKERS=4

# ── React ─────────────────────────────────────────────────────────
REACT_APP_API_URL=https://camrail-predict.intranet.cm/api

# ── Domaine intranet ──────────────────────────────────────────────
NGINX_HOST=camrail-predict.intranet.cm
